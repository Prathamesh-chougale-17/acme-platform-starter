{
  "name": "@acme/api",
  "type": "module",
  "scripts": {
    "dev": "pnpm exec dotenv -e .env -- tsx watch src/index.ts",
    "build": "pnpm exec tsup --config tsup.config.ts",
    "start": "pnpm exec dotenv -e .env -- node dist/index.cjs",
    "worker": "pnpm exec dotenv -e .env -- node dist/worker.cjs",
    "lint": "pnpm exec eslint .",
    "typecheck": "pnpm exec tsc --noEmit",
    "test": "pnpm exec vitest run"
  },
  "dependencies": {
    "@acme/auth": "workspace:*",
    "@acme/config": "workspace:*",
    "@acme/db": "workspace:*",
    "@acme/jobs": "workspace:*",
    "@acme/logger": "workspace:*",
    "@acme/observability": "workspace:*",
    "@acme/shared": "workspace:*",
    "@hono/node-server": "^1.19.13",
    "@hono/zod-validator": "^0.7.6",
    "@opentelemetry/api": "^1.9.0",
    "@sentry/node": "^10.48.0",
    "bullmq": "^5.61.2",
    "hono": "^4.12.12",
    "nodemailer": "^8.0.5",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "zod": "^4.3.6"
  }
}
