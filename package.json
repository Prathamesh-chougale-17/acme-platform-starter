{
  "name": "acme-platform",
  "version": "0.3.5",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Prathamesh-chougale-17/acme-platform-starter.git"
  },
  "homepage": "https://github.com/Prathamesh-chougale-17/acme-platform-starter#readme",
  "bugs": {
    "url": "https://github.com/Prathamesh-chougale-17/acme-platform-starter/issues"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start": "turbo run start --filter=@acme/web --filter=@acme/api",
    "lint": "turbo run lint",
    "query": "turbo query",
    "query:packages": "turbo query ls",
    "query:packages:affected": "turbo query ls --affected",
    "query:affected": "turbo query affected",
    "format": "pnpm exec prettier --write .",
    "format:check": "pnpm exec prettier --check .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test --filter=!@acme/web-e2e",
    "test:e2e": "pnpm --filter @acme/web-e2e run test:e2e",
    "auth:generate": "pnpm exec dotenv -e apps/api/.env -e apps/web/.env -- auth generate --config packages/auth/src/server.ts --output packages/db/src/schema/auth.ts --yes && pnpm exec prettier --write packages/db/src/schema/auth.ts",
    "db:generate": "pnpm exec dotenv -e apps/api/.env -- drizzle-kit generate --config=packages/db/drizzle.config.ts",
    "db:migrate": "pnpm exec dotenv -e apps/api/.env -- tsx packages/db/src/migrate.ts",
    "db:studio": "pnpm exec dotenv -e apps/api/.env -- drizzle-kit studio --config=packages/db/drizzle.config.ts",
    "prepare": "node scripts/prepare.mjs",
    "release:patch": "pnpm exec standard-version --release-as patch",
    "release:minor": "pnpm exec standard-version --release-as minor",
    "release:major": "pnpm exec standard-version --release-as major",
    "release:build-package": "pnpm --filter @acme/create build && node scripts/build-create-package.mjs",
    "release:verify": "pnpm release:build-package && node scripts/verify-create-package.mjs",
    "release:pack:dry-run": "pnpm release:build-package && npm pack --dry-run ./dist/create-acme-platform"
  },
  "devDependencies": {
    "@clack/prompts": "^1.2.0",
    "@eslint/js": "^9.39.1",
    "@next/eslint-plugin-next": "16.2.3",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.4",
    "auth": "^1.6.2",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-turbo": "^2.9.6",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.7.4",
    "standard-version": "^9.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "turbo": "^2.9.6",
    "typescript": "5.9.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "pnpm exec prettier --write",
      "pnpm exec eslint --fix"
    ],
    "*.{json,md,css,yml,yaml}": [
      "pnpm exec prettier --write"
    ]
  },
  "packageManager": "pnpm@10.17.0",
  "engines": {
    "node": ">=22.0.0"
  }
}
